NODE_ENV=production
PORT=4001

# PostgreSQL (Supabase 또는 Railway)
DATABASE_URL=postgresql://user:password@host:5432/portfolio_db

# Redis (Upstash)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=3600

# CORS — 프론트엔드 URL (Vercel)
CORS_ORIGIN=https://taebinkim.vercel.app

# 로깅
LOG_LEVEL=warn
