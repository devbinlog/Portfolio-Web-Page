// Prisma 스키마 — My Portfolio World
// docs/03_data.md 기반으로 설계

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// 관리자
// ──────────────────────────────────────────

enum AdminRole {
  ADMIN
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

// ──────────────────────────────────────────
// 프로필
// ──────────────────────────────────────────

model Profile {
  id            String  @id @default(uuid())
  name          String
  roleTitle     String
  tagline       String
  bio           String  @db.Text
  workingMethod String  @db.Text
  avatarUrl     String?
  resumeUrl     String?
  location      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  socialLinks SocialLink[]

  @@map("profiles")
}

model SocialLink {
  id        String   @id @default(uuid())
  profileId String
  platform  String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

// ──────────────────────────────────────────
// 카테고리
// ──────────────────────────────────────────

model Category {
  id           String @id @default(uuid())
  name         String
  slug         String @unique
  objectFamily String
  order        Int    @default(0)
  createdAt    DateTime @default(now())

  projects          Project[] @relation("PrimaryCategory")
  secondaryProjects Project[] @relation("SecondaryCategory")

  @@map("categories")
}

// ──────────────────────────────────────────
// 프로젝트
// ──────────────────────────────────────────

model Project {
  id                  String   @id @default(uuid())
  title               String
  slug                String   @unique
  summary             String
  description         String   @db.Text
  categoryId          String
  secondaryCategoryId String?
  year                Int
  role                String
  contribution        String   @db.Text
  techStack           String[]
  keyLearnings        String   @db.Text
  workingApproach     String?  @db.Text
  thumbnailUrl        String?
  heroImageUrl        String?
  codeSnippets        Json?
  isFeatured          Boolean  @default(false)
  featuredOrder       Int?
  isPublished         Boolean  @default(false)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  category          Category  @relation("PrimaryCategory", fields: [categoryId], references: [id])
  secondaryCategory Category? @relation("SecondaryCategory", fields: [secondaryCategoryId], references: [id])

  media     ProjectMedia[]
  documents ProjectDocument[]
  links     ProjectLink[]
  tags      ProjectTag[]

  @@map("projects")
}

// ──────────────────────────────────────────
// 프로젝트 미디어
// ──────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO_PLACEHOLDER
  VIDEO_EMBED
}

model ProjectMedia {
  id               String    @id @default(uuid())
  projectId        String
  type             MediaType
  url              String?
  placeholderLabel String?
  embedId          String?
  altText          String?
  caption          String?
  order            Int       @default(0)
  isPlaceholder    Boolean   @default(false)
  createdAt        DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_media")
}

// ──────────────────────────────────────────
// 프로젝트 문서
// ──────────────────────────────────────────

enum DocumentType {
  REPORT
  PRESENTATION
  MARKDOWN
  OTHER
}

model ProjectDocument {
  id               String       @id @default(uuid())
  projectId        String
  type             DocumentType
  title            String
  url              String?
  placeholderLabel String?
  isPlaceholder    Boolean      @default(false)
  order            Int          @default(0)
  createdAt        DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_documents")
}

// ──────────────────────────────────────────
// 프로젝트 링크
// ──────────────────────────────────────────

enum LinkType {
  GITHUB
  DEMO
  DOCS
  EXTERNAL
}

model ProjectLink {
  id        String   @id @default(uuid())
  projectId String
  type      LinkType
  label     String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_links")
}

// ──────────────────────────────────────────
// 태그
// ──────────────────────────────────────────

model Tag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  projects ProjectTag[]

  @@map("tags")
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@map("project_tags")
}

// ──────────────────────────────────────────
// 연락 메시지
// ──────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ──────────────────────────────────────────
// 자산
// ──────────────────────────────────────────

model Asset {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())

  @@map("assets")
}

// ──────────────────────────────────────────
// 감사 로그
// ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}
