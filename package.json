{
  "name": "my-portfolio-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build --filter=web",
    "lint": "turbo lint --filter=web",
    "typecheck": "turbo typecheck --filter=web",
    "test": "turbo test --filter=web",
    "test:e2e": "pnpm --filter=web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter=web db:generate",
    "db:migrate": "pnpm --filter=web db:migrate",
    "db:seed": "pnpm --filter=web db:seed",
    "db:studio": "pnpm --filter=web db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
